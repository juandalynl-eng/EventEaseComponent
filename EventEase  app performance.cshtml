<div class="event-card" @onclick="NavigateToDetails">
    <h3 class="event-name">@EventName</h3>
    <p class="event-date">@EventDate.ToString("MMMM dd, yyyy")</p>
    <p class="event-location">@Location</p>
</div>

@code {
    [Parameter] public int Id { get; set; }
    [Parameter] public string EventName { get; set; } = string.Empty;
    [Parameter] public DateTime EventDate { get; set; }
    [Parameter] public string Location { get; set; } = string.Empty;

    [Inject] NavigationManager Nav { get; set; } = default!;

    private void NavigateToDetails()
    {
        if (Id <= 0)
            return;

        Nav.NavigateTo($"/events/{Id}");
    }
}
<Virtualize Items="@Events" Context="ev">
    <EventCard
        Id="@ev.Id"
        EventName="@ev.Name"
        EventDate="@ev.Date"
        Location="@ev.Location" />
</Virtualize>
@page "/events/{id:int}"
@inject NavigationManager Nav
@inject IEventService EventService

@if (IsInvalid)
{
    <p>Redirecting...</p>
}
else if (Event is null)
{
    <p>Loading...</p>
}
else
{
    <h3>@Event.Name</h3>
    <p>@Event.Date.ToString("MMMM dd, yyyy")</p>
    <p>@Event.Location</p>
}

@code {
    [Parameter] public int Id { get; set; }
    public EventModel? Event { get; set; }
    public bool IsInvalid { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (Id <= 0)
        {
            IsInvalid = true;
            Nav.NavigateTo("/not-found");
            return;
        }

        Event = await EventService.GetEventById(Id);

        if (Event is null)
        {
            IsInvalid = true;
            Nav.NavigateTo("/not-found");
        }
    }
}
<EditForm Model="_model" OnValidSubmit="Submit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <InputText @bind-Value="_model.FirstName" />
    <ValidationMessage For="@(() => _model.FirstName)" />

    <InputText @bind-Value="_model.LastName" />
    <ValidationMessage For="@(() => _model.LastName)" />

    <InputText @bind-Value="_model.Email" />
    <ValidationMessage For="@(() => _model.Email)" />

    <button type="submit">Register</button>
</EditForm>

@code {
    [Parameter] public int EventId { get; set; }
    private RegistrationModel _model = new();

    private void Submit()
    {
        // Registration logic
    }
}
public class UserSessionService
{
    public string? UserId { get; private set; }
    public string? Email { get; private set; }

    public bool IsLoggedIn => UserId is not null;

    public void SetUser(string userId, string email)
    {
        UserId = userId;
        Email = email;
    }
}
public class AttendanceTrackerService
{
    private readonly Dictionary<int, HashSet<string>> _attendance = new();

    public void MarkAttendance(int eventId, string userId)
    {
        if (!_attendance.TryGetValue(eventId, out var set))
            _attendance[eventId] = set = new HashSet<string>();

        set.Add(userId);
    }

    public int GetCount(int eventId) =>
        _attendance.TryGetValue(eventId, out var set) ? set.Count : 0;
}
